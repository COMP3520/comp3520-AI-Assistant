      ],
      "id": "63950e20-1a17-40ab-b4f9-5317f2b05b71",
      "name": "Success Response1"
    },
    {
      "parameters": {
        "command": "=powershell -Command \"[Console]::OutputEncoding = [System.Text.Encoding]::UTF8; Add-Type -AssemblyName System.Windows.Forms; $nl = [Environment]::NewLine; $msg = 'Action: {{ $json.description.replace(/'/g, \"''\") }}' + $nl + $nl + 'Command: {{ $json.command.replace(/'/g, \"''\") }}' + $nl + $nl + 'Description: {{ $json.riskReason.replace(/'/g, \"''\") }}' + $nl + $nl + 'Risk: {{ $json.riskEmoji }}{{ $json.risk }}' + $nl + $nl + 'Approve?'; $res = [System.Windows.Forms.MessageBox]::Show($msg, 'n8n Approval', 'YesNo'); if($res -eq 'Yes'){'approved'}else{'denied'}\""
      },

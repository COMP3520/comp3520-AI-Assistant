      ],
      "id": "9259bf3c-e0bb-4080-a59e-fc8198999ed8",
      "name": "Denied Response1"
    },
    {
      "parameters": {
        "jsCode": "const stdout = $input.first().json.stdout?.trim() || \"\";\nconst stderr = $input.first().json.stderr?.trim() || \"\";\nconst error = $input.first().json.error?.trim() || \"\";\nconst code = $input.first().json.exitCode ?? 0;\n\nconst failed = !!error || code !== 0;\n\nreturn {\n  json: {\n    result: failed\n      ? `Command failed${code !== 0 ? ` (exit ${code})` : \"\"}:\\n${error || stderr || \"No error details.\"}`\n      : `Command executed successfully.${stdout ? `\\n\\`\\`\\`\\n${stdout}\\n\\`\\`\\`` : \"\"}`\n  }\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1312,
        576
      ],
      "id": "f12d6e01-86d6-43a7-aae8-e93fa1f4bc47",
      "name": "Format Result1"
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "id": "success-result-001",
              "name": "result",
              "value": "={{ $json.result }}",
              "type": "string"
            }
          ]
        },
        "options": {}
      },
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,

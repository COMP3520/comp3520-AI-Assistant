      "id": "8fc8e6b7-bc81-41db-ab6c-7dbd5fbaa1c3",
      "typeVersion": 1.1,
      "name": "When Executed by Another Workflow",
      "type": "n8n-nodes-base.executeWorkflowTrigger",
      "position": [
        -176,
        672
      ]
    },
    {
      "parameters": {
        "jsCode": "const raw  = ($input.first().json.stdout || '').trim().toLowerCase();\nconst task = $('When Executed by Another Workflow').first().json.task || '';\n\nlet os = 'unknown';\nif (raw.includes('darwin'))                                                   os = 'macos';\nelse if (raw.includes('linux'))                                               os = 'linux';\nelse if (raw.includes('windows') || raw.includes('mingw') || raw.includes('cygwin')) os = 'windows';\n\nreturn [{ json: { detectedOS: os, task } }];"
      },
      "id": "5d6836f4-8a2e-4491-b300-6798b6e666c6",
      "name": "Parse OS",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        192,
        672
      ]
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "={{ $json.task }}",
        "options": {
          "systemMessage": "=You are a multi-platform terminal assistant for macOS, Linux, and Windows.\n\nThe detected OS is: {{ $json.detectedOS }}. Task: {{ $json.task }}.\n\nThe user wants to perform a task on their machine. Convert their plain-English request into the correct shell command for the detected OS.\n\nCRITICAL RULES:\n1. Use ONLY the detected OS above — never output commands for another OS.\n2. Extract file paths, URLs, app names EXACTLY as the user typed them.\n3. Wrap paths that contain spaces in quotes appropriate for the OS.\n4. Respond ONLY with this JSON — no markdown, no backticks, no extra text:\n\n{\"command\":\"<exact shell command for detected OS>\",\"description\":\"<one sentence: what this command does>\",\"os\":\"<macos|linux|windows>\",\"risk\":\"<low|medium|high>\",\"riskReason\":\"<one sentence explaining the risk level>\"}\n\nRisk guide:\n- low   = read-only / open apps / search queries\n- medium = create or modify files / install software / change settings\n- high  = delete files / kill processes / system-wide or irreversible changes "
        }
      },
      "id": "bbb11ebe-f03d-421c-b6fd-271ee8c22c67",
      "name": "Ollama Agent",
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 1.7,
      "position": [
        352,
        672
      ]
    },
    {
      "parameters": {
        "model": "llama3.2:latest",
        "options": {}
      },
      "id": "f81cb708-ea83-43ff-b165-f76207e6ef8c",
      "name": "Ollama Chat Model",
      "type": "@n8n/n8n-nodes-langchain.lmChatOllama",
      "typeVersion": 1,
      "position": [
        352,
        848
      ],
      "credentials": {
        "ollamaApi": {
          "id": "abwT4youa7pGkeXY",
          "name": "Ollama account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const rawOutput = $input.first().json.output || $input.first().json.text || '';\nconst cleaned   = rawOutput.replace(/```json|```/g, '').trim();\n\nlet parsed;\ntry { \n  parsed = JSON.parse(cleaned); \n} catch (e) {\n  const match = cleaned.match(/{[\\s\\S]*}/);\n  if (match) { \n    try { parsed = JSON.parse(match[0]); } \n    catch (e2) { throw new Error('Cannot parse Ollama output: ' + rawOutput); } \n  } else { \n    throw new Error('Cannot parse Ollama output: ' + rawOutput); \n  }\n}\n\nif (!parsed.command) throw new Error('No command field in: ' + rawOutput);\n\n// 1. Determine the OS\nconst detectedOS = parsed.os || $('Parse OS').first().json.detectedOS;\n\n// 2. Wrap command in PowerShell if on Windows\nlet finalCommand = parsed.command;\nif (detectedOS === 'windows') {\n  // We escape double quotes inside the command so they don't break the wrapper\n  const escapedCommand = parsed.command.replace(/\"/g, '\\\\\"');\n  finalCommand = `powershell -Command \"${escapedCommand}\"`;\n}\n\nconst riskEmoji = { low: '🟢', medium: '🟡', high: '🔴' }[parsed.risk] || '⚪';\n\nreturn [{ json: {\n  command:     finalCommand, // This is now the \"ready-to-run\" command\n  description: parsed.description || '',\n  os:          detectedOS,\n  risk:        parsed.risk || 'low',\n  riskReason:  parsed.riskReason || '',\n  riskEmoji\n}}];"
      },
      "id": "3823ac5e-581c-475f-833b-55419411641a",
      "name": "Parse Ollama JSON",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        576,
        672
      ]
    },
    {
      "parameters": {
